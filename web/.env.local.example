# Copie este arquivo para ".env.local" e preencha com os valores do seu
# projeto Supabase (Project Settings > API).
#
# Estes dois valores sao PUBLICOS (seguros para o frontend).
# NUNCA coloque aqui a chave "service_role" nem a senha do banco.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-public-key-aqui
